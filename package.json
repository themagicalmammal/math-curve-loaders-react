{
  "name": "math-curve-loaders-react-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "A collection of mathematical curve loading animations as reusable React components",
  "scripts": {
    "dev": "pnpm --filter @math-curve-loaders/react dev",
    "build:lib": "pnpm --filter @math-curve-loaders/react build",
    "dev:gallery": "pnpm --filter @math-curve-loaders/gallery dev",
    "build:gallery": "pnpm --filter @math-curve-loaders/gallery build",
    "dev:all": "concurrently \"pnpm --filter @math-curve-loaders/react dev\" \"pnpm --filter @math-curve-loaders/gallery dev\"",
    "lint": "oxlint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "puppeteer": "^25.3.0"
  },
  "engines": {
    "pnpm": ">=8.0.0"
  }
}
